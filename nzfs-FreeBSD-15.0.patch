+static char *
+strdupcat(const char *s1, ...) {
+  	char *res, *s;
+	size_t len;
+	va_list ap;
+	
+	va_start(ap, s1);
+	len = strlen(s1);
+	while ((s = va_arg(ap, char *)) != NULL)
+	  	len += strlen(s);
+	va_end(ap);
+	
+	res = malloc(len+1);
+	if (!res)
+	  	return NULL;
+	strcpy(res, s1);
+	
+	va_start(ap, s1);
+	while ((s = va_arg(ap, char *)) != NULL)
+	  	strcat(res, s);
+	va_end(ap);
+	
+	return res;
+}
